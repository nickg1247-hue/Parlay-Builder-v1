APP_ENV=development
DATABASE_URL=sqlite:///./data/parlay_builder.db
HOST=127.0.0.1
PORT=8000
# --- Live sportsbook odds (Odds API) — default off; see DEV.md "Enable live odds" ---
# To enable: set USE_LIVE_ODDS=true, add ODDS_API_KEY, run scripts/enable_live_odds.ps1
USE_LIVE_ODDS=false
ODDS_API_KEY=
# Recommended when live odds enabled:
# USE_LIVE_ODDS=true
# ODDS_API_KEY=your_key_here
# ODDS_HOURLY_REFRESH=true
# ODDS_API_MAX_PER_HOUR=25
# ODDS_API_MAX_PER_DAY=500
#
# Strict personal caps (UTC) — low credit usage:
# ODDS_API_MAX_PER_HOUR=3
# ODDS_API_MAX_PER_DAY=15
# ODDS_REPO_MIN_REFRESH_SECONDS=300
# Optional: override persistent odds snapshot directory (default data/processed/odds_repository)
ODDS_REPOSITORY_DIR=
# Hourly in-app refresh of today's lines (quota-gated; requires USE_LIVE_ODDS=true)
ODDS_HOURLY_REFRESH=false
# Hard API rate limits (UTC) — our local guardrails, not Odds API's monthly pool
# 20k credits/month ≈ 667/day average → cap at 650/day for ~30-day runway
ODDS_API_MAX_PER_HOUR=25
ODDS_API_MAX_PER_DAY=100
ODDS_API_MAX_CREDITS_PER_HOUR=200
ODDS_API_MAX_CREDITS_PER_DAY=650
# Prop fetches: single US region halves credit cost vs us,us2
ODDS_PROP_REGIONS=us
# Slate scan defaults (full extended markets + runs)
PROP_SLATE_BOOKMAKER=draftkings
# MAX_PROP_LINES_TO_SCORE=0 means score every parsed line (default)
MAX_PROP_LINES_TO_SCORE=0
# Min seconds between live pulls for the same date (board Run live respects this unless forced)
ODDS_REPO_MIN_REFRESH_SECONDS=300
# UI display blend: fraction of model (0.5 = 50/50; 0.7 = 70% model / 30% market)
DISPLAY_BLEND_MODEL_WEIGHT=0.5
# Totals pick margin vs book line (runs)
TOTALS_PICK_MARGIN=0.0
# --- Admin login (boards + model lab) ---
# Local dev: leave ADMIN_PASSWORD empty and APP_ENV=development (auth off).
# Production: set APP_ENV=production + ADMIN_PASSWORD (boards lock even if password missing).
# Prop slip + sportsbook export: enabled by default. Set PROP_SLIP_PUBLIC=false to disable.
# PROP_SLIP_PUBLIC=false
# --- End-user accounts (player props access) ---
# Production: props require sign-in by default (games/news stay public).
# Require sign-in for props explorer (off by default; set true to enable soft gate)
# PROPS_REQUIRE_VERIFIED_USER=true
# USER_REGISTRATION_ENABLED=true
# PUBLIC_SITE_URL=https://ntgsports.com
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
# EMAIL_FROM=noreply@ntgsports.com
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=choose_a_strong_password
# --- Session secrets (set in production; keep distinct from each other) ---
# USER_SESSION_SECRET=long_random_string_for_end_user_cookies
# ADMIN_SESSION_SECRET=long_random_string_for_admin_board_cookies
# Set false on HTTP-only VPS until HTTPS is live (otherwise login cookie is dropped)
# ADMIN_COOKIE_SECURE=false
# Force auth in dev: REQUIRE_ADMIN_AUTH=true
# Disable auth on production (not recommended): ADMIN_AUTH_DISABLED=true
# Morning cron: skip totals model on VPS without train_mlb_totals (default true)
# MORNING_SKIP_TOTALS=true
# --- College Football (CFBD) historical ingest ---
# Free API key: https://collegefootballdata.com/key
CFBD_API_KEY=
